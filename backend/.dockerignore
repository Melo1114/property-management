# Version control
.git
.gitignore

# Python cache
__pycache__
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info
dist/
build/

# Virtual environments
.venv
venv/
env/

# Local dev database — never ship SQLite in prod image
db.sqlite3
*.sqlite3

# Local media uploads — Azure Blob handles this in prod
media/

# Static (collectstatic runs inside Docker build)
staticfiles/

# Tests
.coverage
.pytest_cache
htmlcov/

# Environment files — secrets must come from Azure App Settings, not baked in
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Docker
Dockerfile*
docker-compose*
.dockerignore
